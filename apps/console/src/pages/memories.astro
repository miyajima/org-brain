---
import BaseLayout from "../layouts/BaseLayout.astro";

type MemoryRow = {
  id: string;
  project_id: string | null;
  content: string;
  summary: string | null;
  tags: string[];
  source: string;
  external_key: string | null;
  created_at: number;
  kind: "episodic" | "semantic" | "org_knowledge";
  lifecycle_state: "active" | "suppressed" | "consolidated" | "promoted";
  current_version: number;
  last_accessed_at: number | null;
  confidence_score: number | null;
  utility_score: number | null;
};

type MemorySearchResult = {
  kind: "memory" | "doc";
  id: string;
  summary: string | null;
  content_preview: string;
  score: number | null;
  source: string;
  created_at: number;
  memory_kind?: "episodic" | "semantic" | "org_knowledge";
  lifecycle_state?: "active" | "suppressed" | "consolidated" | "promoted";
  current_version?: number;
};

type MemoryProfileItem = {
  id: string;
  project_id: string | null;
  summary: string;
  content_preview: string;
  source: string;
  created_at: number;
  tags: string[];
  memory_kind: "episodic" | "semantic" | "org_knowledge";
  lifecycle_state: "active" | "suppressed" | "consolidated" | "promoted";
  current_version: number;
  last_accessed_at: number | null;
  confidence_score: number | null;
  utility_score: number | null;
};

type SearchResponse = {
  tenant_id: string;
  project_id: string | null;
  q: string;
  rewrite_query: boolean;
  search_mode: "memories" | "hybrid";
  include_history: boolean;
  results: MemorySearchResult[];
  meta: {
    search_strategy: string;
    matched_count: number;
    returned_count: number;
    fallback_used: boolean;
    variant_count: number;
  };
};

type ProfileResponse = {
  tenant_id: string;
  project_id: string | null;
  durable: MemoryProfileItem[];
  recent: MemoryProfileItem[];
  search_results: MemorySearchResult[];
  meta: {
    durable_count: number;
    recent_count: number;
  };
};

type MemoryListPage = {
  tenant_id: string;
  project_id: string | null;
  source: string | null;
  items: MemoryRow[];
  meta: {
    limit: number;
    offset: number;
    total: number;
    has_next: boolean;
    has_prev: boolean;
    canonical_count: number;
    digest_count: number;
    compacted_count: number;
  };
};

type ApiOk<T> = { ok: true; data: T };
type ApiErr = { ok: false; error?: { code?: string; message?: string } };
type ApiResponse<T> = ApiOk<T> | ApiErr;

type DetailRecord = {
  id: string;
  kind: "memory" | "doc";
  title: string;
  summary: string;
  preview: string;
  source: string;
  project_id: string | null;
  external_key: string | null;
  created_at: number;
  tags: string[];
  score: number | null;
  content: string;
  memory_kind: "episodic" | "semantic" | "org_knowledge";
  lifecycle_state: "active" | "suppressed" | "consolidated" | "promoted";
  current_version: number;
  last_accessed_at: number | null;
  confidence_score: number | null;
  utility_score: number | null;
};

const url = Astro.url;
const params = url.searchParams;

const tenantId = params.get("tenant_id")?.trim() || "default";
const projectId = params.get("project_id")?.trim() || "";
const query = params.get("q")?.trim() || "";
const selectedId = params.get("selected")?.trim() || "";
const view = ["search", "profile", "maintenance"].includes(params.get("view") ?? "")
  ? (params.get("view") as "search" | "profile" | "maintenance")
  : "search";
const rewriteQuery = params.get("rewrite_query") !== "0";
const searchMode = params.get("search_mode") === "memories" ? "memories" : "hybrid";
const includeHistory = params.get("include_history") !== "0";
const pageSize = Math.min(50, Math.max(10, Number.parseInt(params.get("page_size") ?? "20", 10) || 20));
const page = Math.max(1, Number.parseInt(params.get("page") ?? "1", 10) || 1);
const offset = (page - 1) * pageSize;

function formatDate(timestamp: number): string {
  return new Intl.DateTimeFormat("ja-JP", {
    timeZone: "Asia/Tokyo",
    dateStyle: "medium",
    timeStyle: "short"
  }).format(new Date(timestamp));
}

function trimText(value: string | null | undefined, limit = 180): string {
  const normalized = String(value ?? "").replace(/\s+/g, " ").trim();
  if (!normalized) return "";
  if (normalized.length <= limit) return normalized;
  return `${normalized.slice(0, Math.max(0, limit - 1))}...`;
}

function makeHref(overrides: Record<string, string | null | undefined>): string {
  const next = new URLSearchParams(params);
  for (const [key, value] of Object.entries(overrides)) {
    if (value === null || value === undefined || value === "") {
      next.delete(key);
    } else {
      next.set(key, value);
    }
  }
  const queryString = next.toString();
  return queryString ? `${url.pathname}?${queryString}` : url.pathname;
}

async function fetchApi<T>(path: string, init?: RequestInit): Promise<ApiResponse<T> | null> {
  const response = await fetch(new URL(path, url), init);
  const payload = (await response.json().catch(() => null)) as ApiResponse<T> | null;
  if (!response.ok) {
    return {
      ok: false,
      error: payload && "error" in payload ? payload.error : { code: "http_error", message: `HTTP ${response.status}` }
    };
  }
  if (!payload || payload.ok === false) {
    return payload ?? { ok: false, error: { code: "parse_error", message: "Invalid JSON response" } };
  }
  return payload;
}

function buildDetailRecord(
  selected: string,
  corpusItems: MemoryRow[],
  searchResults: MemorySearchResult[],
  profileItems: MemoryProfileItem[]
): DetailRecord | null {
  const row = corpusItems.find((item) => item.id === selected);
  if (row) {
    return {
      id: row.id,
      kind: "memory",
      title: row.summary || trimText(row.content, 80),
      summary: row.summary || "",
      preview: trimText(row.content, 320),
      source: row.source,
      project_id: row.project_id,
      external_key: row.external_key,
      created_at: row.created_at,
      tags: row.tags,
      score: searchResults.find((item) => item.id === selected)?.score ?? null,
      content: row.content,
      memory_kind: row.kind,
      lifecycle_state: row.lifecycle_state,
      current_version: row.current_version,
      last_accessed_at: row.last_accessed_at,
      confidence_score: row.confidence_score,
      utility_score: row.utility_score
    };
  }

  const searchItem = searchResults.find((item) => item.id === selected);
  if (searchItem) {
    const profileItem = profileItems.find((item) => item.id === selected);
    return {
      id: searchItem.id,
      kind: searchItem.kind,
      title: searchItem.summary || trimText(searchItem.content_preview, 80),
      summary: searchItem.summary || "",
      preview: trimText(searchItem.content_preview, 320),
      source: searchItem.source,
      project_id: profileItem?.project_id ?? null,
      external_key: null,
      created_at: searchItem.created_at,
      tags: profileItem?.tags ?? [],
      score: searchItem.score,
      content: searchItem.content_preview,
      memory_kind: profileItem?.memory_kind ?? searchItem.memory_kind ?? "episodic",
      lifecycle_state: profileItem?.lifecycle_state ?? searchItem.lifecycle_state ?? "active",
      current_version: profileItem?.current_version ?? searchItem.current_version ?? 1,
      last_accessed_at: profileItem?.last_accessed_at ?? null,
      confidence_score: profileItem?.confidence_score ?? null,
      utility_score: profileItem?.utility_score ?? null
    };
  }

  const profileItem = profileItems.find((item) => item.id === selected);
  if (profileItem) {
    return {
      id: profileItem.id,
      kind: "memory",
      title: profileItem.summary,
      summary: profileItem.summary,
      preview: trimText(profileItem.content_preview, 320),
      source: profileItem.source,
      project_id: profileItem.project_id,
      external_key: null,
      created_at: profileItem.created_at,
      tags: profileItem.tags,
      score: null,
      content: profileItem.content_preview,
      memory_kind: profileItem.memory_kind,
      lifecycle_state: profileItem.lifecycle_state,
      current_version: profileItem.current_version,
      last_accessed_at: profileItem.last_accessed_at,
      confidence_score: profileItem.confidence_score,
      utility_score: profileItem.utility_score
    };
  }

  return null;
}

function addSuggestion(counts: Map<string, number>, raw: string | null | undefined, weight = 1) {
  const normalized = String(raw ?? "").trim().toLowerCase();
  if (!normalized) return;
  if (normalized.length < 3) return;

  const blocked = new Set([
    "org-bus",
    "canonical-memory",
    "memory-digest",
    "compacted",
    "memory_measurement",
    "hook",
    "promoted",
    "maintenance",
    "memory",
    "none",
    "default"
  ]);

  if (blocked.has(normalized)) return;
  counts.set(normalized, (counts.get(normalized) ?? 0) + weight);
}

function extractSearchTerms(value: string | null | undefined): string[] {
  return (String(value ?? "").toLowerCase().match(/[a-z][a-z0-9-]{2,}/g) ?? []).slice(0, 8);
}

function rowCardClass(selected: boolean): string {
  return [
    "group relative overflow-hidden rounded-[24px] border p-4 transition duration-200",
    "shadow-[0_20px_60px_rgba(0,0,0,0.24)]",
    selected
      ? "border-amber-300/45 bg-white/[0.09] ring-1 ring-amber-300/20"
      : "border-white/8 bg-white/[0.04] hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.06]"
  ].join(" ");
}

function tabClass(active: boolean): string {
  return [
    "inline-flex min-h-11 items-center justify-center rounded-full border px-4 text-sm font-semibold transition duration-200",
    active
      ? "border-amber-300/40 bg-amber-300/20 text-amber-50 shadow-[0_12px_40px_rgba(212,175,55,0.18)]"
      : "border-white/8 bg-white/[0.04] text-zinc-300 hover:border-white/18 hover:bg-white/[0.06] hover:text-white"
  ].join(" ");
}

const listPayload = await fetchApi<MemoryListPage>(
  `/api/v1/memories?tenant_id=${encodeURIComponent(tenantId)}&project_id=${encodeURIComponent(projectId)}&limit=${pageSize}&offset=${offset}&paginated=1`
);

const searchPayload =
  query.length > 0
    ? await fetchApi<SearchResponse>("/api/v1/memories/search", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          tenant_id: tenantId,
          project_id: projectId || null,
          q: query,
          limit: 12,
          rewrite_query: rewriteQuery,
          search_mode: searchMode,
          include_history: includeHistory
        })
      })
    : null;

const profilePayload = await fetchApi<ProfileResponse>("/api/v1/memories/profile", {
  method: "POST",
  headers: { "content-type": "application/json" },
  body: JSON.stringify({
    tenant_id: tenantId,
    project_id: projectId || null,
    limit_durable: 8,
    limit_recent: 8,
    rewrite_query: rewriteQuery,
    search_mode: searchMode
  })
});

const listPage = listPayload?.ok ? listPayload.data : null;
const corpusItems = listPage?.items ?? [];
const searchResults = searchPayload?.ok ? searchPayload.data.results : [];
const profile = profilePayload?.ok ? profilePayload.data : null;
const durableRows = profile?.durable ?? [];
const recentRows = profile?.recent ?? [];
const maintenanceRows = corpusItems.filter((item) =>
  item.tags.some((tag) => ["canonical-memory", "memory-digest", "compacted"].includes(tag))
);
const maintenanceTagCounts = maintenanceRows.reduce<Record<string, number>>((acc, item) => {
  for (const tag of item.tags) {
    if (!["canonical-memory", "memory-digest", "compacted"].includes(tag)) continue;
    acc[tag] = (acc[tag] ?? 0) + 1;
  }
  return acc;
}, {});
const maintenanceProjectCounts = maintenanceRows.reduce<Record<string, number>>((acc, item) => {
  const project = item.project_id || "no-project";
  acc[project] = (acc[project] ?? 0) + 1;
  return acc;
}, {});
const maintenanceProjectRows = Object.entries(maintenanceProjectCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4);
const recentHighlights = recentRows.slice(0, 3);
const searchLandingRows = (recentHighlights.length > 0 ? recentHighlights : durableRows.slice(0, 3)).slice(0, 3);
const searchLandingKind = recentHighlights.length > 0 ? "recent" : "durable";
const quickPickRows = (recentHighlights.length > 0 ? recentHighlights : durableRows.slice(0, 3)).slice(0, 3);

const suggestionCounts = new Map<string, number>();
for (const row of recentRows) {
  for (const tag of row.tags) addSuggestion(suggestionCounts, tag, 3);
  for (const term of extractSearchTerms(row.summary)) addSuggestion(suggestionCounts, term, 3);
}
for (const row of durableRows) {
  for (const tag of row.tags) addSuggestion(suggestionCounts, tag, 2);
  for (const term of extractSearchTerms(row.summary)) addSuggestion(suggestionCounts, term, 2);
}
for (const row of corpusItems.slice(0, 24)) {
  for (const tag of row.tags) addSuggestion(suggestionCounts, tag, 1);
  for (const term of extractSearchTerms(row.summary || row.content)) addSuggestion(suggestionCounts, term, 1);
}
for (const seed of ["policy", "diagnosis", "deploy", "maintenance", "command-result", "workaround"]) {
  addSuggestion(suggestionCounts, seed, 1);
}

const searchSuggestions = Array.from(suggestionCounts.entries())
  .sort((left, right) => right[1] - left[1])
  .map(([term]) => term)
  .slice(0, 8);

const datalistSuggestions = [
  ...new Set(
    [
      ...searchSuggestions,
      ...recentRows.map((item) => trimText(item.summary, 80)),
      ...durableRows.map((item) => trimText(item.summary, 80))
    ].filter(Boolean)
  )
].slice(0, 12);

const detail = buildDetailRecord(selectedId, corpusItems, searchResults, [...durableRows, ...recentRows]);
const loadErrors = [...new Set([
  listPayload?.ok === false ? listPayload.error?.message ?? "Memory list could not be loaded" : null,
  searchPayload?.ok === false ? searchPayload.error?.message ?? "Memory search could not be loaded" : null,
  profilePayload?.ok === false ? profilePayload.error?.message ?? "Memory profile could not be loaded" : null
].filter(Boolean) as string[])];

const prevPageHref = listPage?.meta.has_prev ? makeHref({ page: String(page - 1), selected: "" }) : null;
const nextPageHref = listPage?.meta.has_next ? makeHref({ page: String(page + 1), selected: "" }) : null;
const searchTabHref = makeHref({ view: "search", page: String(page) });
const profileTabHref = makeHref({ view: "profile", selected: "" });
const maintenanceTabHref = makeHref({ view: "maintenance", page: String(page), selected: "" });
const clearQueryHref = makeHref({ q: "", selected: "", page: "1" });
---
<BaseLayout title="Memory Explorer">
  <section class="space-y-5">
    <header class="overflow-hidden rounded-[32px] border border-white/10 bg-[linear-gradient(180deg,rgba(7,7,8,0.96)_0%,rgba(10,10,12,0.92)_100%)] p-6 shadow-[0_30px_90px_rgba(0,0,0,0.36)] sm:p-8">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_auto] xl:items-end">
        <div class="space-y-4">
          <p class="surface-label">Memory workspace</p>
          <div class="space-y-3">
            <h1 class="max-w-[11ch] text-5xl font-semibold tracking-[-0.06em] text-white sm:text-6xl xl:text-7xl">Memory Explorer</h1>
            <p class="max-w-3xl text-base leading-8 text-zinc-300 sm:text-lg">
              記憶を探す前から最近の流れが見えるようにして、検索の入口自体も強くしました。まずは recent lane と popular searches から入れます。
            </p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 xl:justify-end">
          <span class="surface-chip">{listPage?.meta.total ?? 0} visible</span>
          <span class="surface-chip">{listPage?.meta.canonical_count ?? 0} canonical</span>
          <span class="surface-chip">{listPage?.meta.digest_count ?? 0} digest</span>
          <span class="surface-chip">{listPage?.meta.compacted_count ?? 0} compacted</span>
          <span class="surface-chip">{profile?.meta.recent_count ?? 0} recent</span>
        </div>
      </div>
    </header>

    <section class="rounded-[32px] border border-white/8 bg-white/[0.04] p-5 shadow-[0_22px_70px_rgba(0,0,0,0.28)] backdrop-blur-xl sm:p-6">
      <div class="flex flex-wrap gap-2">
        <a class={tabClass(view === "search")} href={searchTabHref}>Search</a>
        <a class={tabClass(view === "profile")} href={profileTabHref}>Profile</a>
        <a class={tabClass(view === "maintenance")} href={maintenanceTabHref}>Maintenance</a>
      </div>

      <div class="mt-5 grid gap-4">
        <form class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_12rem]" method="get" action="/memories">
          <input type="hidden" name="view" value={view} />
          <input type="hidden" name="page" value="1" />
          <label class="relative block">
            <span class="surface-label">Search memories</span>
            <svg class="pointer-events-none absolute left-4 top-[3.25rem] h-5 w-5 text-zinc-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle>
              <path d="m20 20-3.5-3.5"></path>
            </svg>
            <input
              class="pl-11"
              type="search"
              name="q"
              value={query}
              list="memory-search-suggestions"
              placeholder="policy / diagnosis / deploy / maintenance"
            />
          </label>
          <button type="submit">Search memory</button>
        </form>
        <datalist id="memory-search-suggestions">
          {datalistSuggestions.map((term) => <option value={term} />)}
        </datalist>

        <div class="rounded-[24px] border border-white/8 bg-black/20 p-4">
          <div class="flex flex-wrap items-center gap-2">
            <p class="surface-label mr-2">Popular searches</p>
            {searchSuggestions.map((term) => (
              <a
                class="inline-flex min-h-9 items-center rounded-full border border-white/10 bg-white/[0.04] px-3 text-sm font-medium text-zinc-200 transition duration-200 hover:-translate-y-0.5 hover:border-amber-300/30 hover:bg-amber-300/10 hover:text-white"
                href={makeHref({ q: term, selected: "", page: "1" })}
              >
                {term}
              </a>
            ))}
            {query && (
              <a class="inline-flex min-h-9 items-center rounded-full border border-white/10 bg-white/[0.03] px-3 text-sm text-zinc-300 transition duration-200 hover:border-white/20 hover:text-white" href={clearQueryHref}>
                Clear search
              </a>
            )}
          </div>
          <p class="mt-3 text-sm leading-7 text-zinc-400">
            サジェストは recent / durable / corpus のタグと summary から組み立てています。完全一致が思いつかない前提で、先に入口を見せます。
          </p>
        </div>

        <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_auto] xl:items-end">
          <form class="grid gap-4 md:grid-cols-2 xl:grid-cols-5" method="get" action="/memories">
            <input type="hidden" name="view" value={view} />
            <input type="hidden" name="q" value={query} />
            <input type="hidden" name="page" value="1" />
            <label>
              <span class="surface-label">Tenant</span>
              <input name="tenant_id" value={tenantId} />
            </label>
            <label>
              <span class="surface-label">Project</span>
              <input name="project_id" value={projectId} placeholder="optional project filter" />
            </label>
            <label>
              <span class="surface-label">Search mode</span>
              <select name="search_mode">
                <option value="hybrid" selected={searchMode === "hybrid"}>hybrid</option>
                <option value="memories" selected={searchMode === "memories"}>memories</option>
              </select>
            </label>
            <label>
              <span class="surface-label">Rewrite query</span>
              <select name="rewrite_query">
                <option value="1" selected={rewriteQuery}>on</option>
                <option value="0" selected={!rewriteQuery}>off</option>
              </select>
            </label>
            <label>
              <span class="surface-label">Page size</span>
              <select name="page_size">
                <option value="10" selected={pageSize === 10}>10</option>
                <option value="20" selected={pageSize === 20}>20</option>
                <option value="50" selected={pageSize === 50}>50</option>
              </select>
            </label>
            <button class="md:col-span-2 xl:col-span-5" type="submit">Apply filters</button>
          </form>

          <div class="rounded-[24px] border border-white/8 bg-black/25 p-4 xl:max-w-xs">
            <p class="surface-label">Search behavior</p>
            <p class="mt-2 text-sm leading-7 text-zinc-300">
              `{includeHistory ? "history on" : "history off"}` で recent context を検索に混ぜます。空検索でも recent lane は先に表示します。
            </p>
          </div>
        </div>
      </div>
    </section>

    {loadErrors.length > 0 && (
      <section class="rounded-[28px] border border-rose-300/25 bg-rose-400/8 p-5 shadow-[0_20px_60px_rgba(0,0,0,0.26)]">
        <strong class="block text-sm font-semibold text-rose-100">Data fetch warning</strong>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-7 text-rose-100/80">
          {loadErrors.map((message) => <li>{message}</li>)}
        </ul>
      </section>
    )}

    <div class="grid gap-5 xl:grid-cols-[minmax(0,1.55fr)_22rem] xl:items-start">
      <section class="space-y-5">
        <div class="card">
          {view === "search" ? (
            <div class="space-y-6">
              {!query && searchLandingRows.length > 0 && (
                <section class="space-y-4">
                  <div class="flex items-end justify-between gap-4">
                    <div>
                      <p class="surface-label">{searchLandingKind === "recent" ? "Recent memory lane" : "Durable memory lane"}</p>
                      <h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-white">
                        {searchLandingKind === "recent" ? "検索しなくても直近 3 件を先に出す" : "Recent が薄いときは durable を先に出す"}
                      </h2>
                    </div>
                    <p class="max-w-xs text-sm leading-7 text-zinc-400">
                      {searchLandingKind === "recent"
                        ? "直近の context を最初から見せて、検索前の手がかり不足を減らします。"
                        : "recent が空でも durable context を入口にして、空画面を避けます。"}
                    </p>
                  </div>
                  <div class="grid gap-4 lg:grid-cols-3">
                    {searchLandingRows.map((item) => (
                      <a class={rowCardClass(selectedId === item.id)} href={makeHref({ selected: item.id })}>
                        <div class="flex items-center justify-between gap-3">
                          <span class="surface-label">{searchLandingKind === "recent" ? "Recent" : "Durable"}</span>
                          <span class="text-xs text-zinc-500">{formatDate(item.created_at)}</span>
                        </div>
                        <div class="mt-3 space-y-2">
                          <h3 class="text-xl font-semibold tracking-[-0.03em] text-white">{item.summary}</h3>
                          <p class="text-sm leading-7 text-zinc-400">{trimText(item.content_preview, 180)}</p>
                        </div>
                        <div class="mt-4 flex flex-wrap gap-2 text-xs text-zinc-500">
                          <span>{item.source}</span>
                          <span>{item.project_id || "no-project"}</span>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              )}

              <section class="space-y-4">
                <div class="flex flex-wrap items-end justify-between gap-4">
                  <div>
                    <p class="surface-label">{query ? "Search results" : "Corpus browser"}</p>
                    <h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-white">
                      {query ? "Ranked matches" : "Search after you skim"}
                    </h2>
                    <p class="mt-2 max-w-2xl text-sm leading-7 text-zinc-400">
                      {query
                        ? "query があるときは top match を優先表示します。search strategy と variant 数も横で確認できます。"
                        : "corpus はページングで維持しつつ、最初の視線は recent lane に寄せています。"}
                    </p>
                  </div>
                  {query && searchPayload?.ok && (
                    <div class="flex flex-wrap gap-2">
                      <span class="surface-chip">{searchPayload.data.meta.search_strategy}</span>
                      <span class="surface-chip">{searchPayload.data.meta.returned_count} results</span>
                      <span class="surface-chip">{searchPayload.data.meta.variant_count} variants</span>
                    </div>
                  )}
                </div>

                {query ? (
                  searchResults.length > 0 ? (
                    <div class="space-y-3">
                      {searchResults.map((item, index) => (
                        <a class={rowCardClass(selectedId === item.id)} href={makeHref({ selected: item.id })}>
                          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                            <div class="flex min-w-0 gap-4">
                              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-amber-300/20 bg-amber-300/12 font-mono text-sm font-semibold text-amber-100">
                                {index + 1}
                              </div>
                              <div class="min-w-0 space-y-2">
                                <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.16em] text-zinc-500">
                                  <span>{item.kind}</span>
                                  <span>{item.source}</span>
                                  <span>{formatDate(item.created_at)}</span>
                                </div>
                                <h3 class="text-xl font-semibold tracking-[-0.03em] text-white">{item.summary || "Untitled result"}</h3>
                                <p class="text-sm leading-7 text-zinc-400">{item.content_preview}</p>
                              </div>
                            </div>
                            <div class="shrink-0 rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs font-medium uppercase tracking-[0.16em] text-zinc-300">
                              {item.score === null ? "n/a" : item.score.toFixed(3)}
                            </div>
                          </div>
                        </a>
                      ))}
                    </div>
                  ) : (
                    <div class="surface-soft-card">
                      <strong class="text-base font-semibold text-white">No matches.</strong>
                      <p class="mt-2 text-sm leading-7 text-zinc-400">query を広げるか、`project` を空にして再検索してください。popular searches からの再検索もすぐできます。</p>
                      <div class="mt-4 flex flex-wrap gap-2">
                        {searchSuggestions.slice(0, 4).map((term) => (
                          <a
                            class="inline-flex min-h-9 items-center rounded-full border border-white/10 bg-white/[0.04] px-3 text-sm text-zinc-200 transition duration-200 hover:border-amber-300/30 hover:bg-amber-300/10 hover:text-white"
                            href={makeHref({ q: term, selected: "", page: "1" })}
                          >
                            {term}
                          </a>
                        ))}
                      </div>
                    </div>
                  )
                ) : corpusItems.length > 0 ? (
                  <div class="space-y-3">
                    {corpusItems.map((item) => (
                      <a class={rowCardClass(selectedId === item.id)} href={makeHref({ selected: item.id })}>
                        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                          <div class="flex min-w-0 gap-4">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.05] font-mono text-sm font-semibold text-amber-100">
                              {item.tags.includes("canonical-memory") ? "C" : item.tags.includes("memory-digest") ? "D" : item.tags.includes("compacted") ? "X" : "M"}
                            </div>
                            <div class="min-w-0 space-y-2">
                              <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.16em] text-zinc-500">
                                <span>{item.source}</span>
                                <span>{item.project_id || "no-project"}</span>
                                <span>{formatDate(item.created_at)}</span>
                              </div>
                              <h3 class="text-xl font-semibold tracking-[-0.03em] text-white">{item.summary || trimText(item.content, 80) || "Untitled memory"}</h3>
                              <p class="text-sm leading-7 text-zinc-400">{trimText(item.content, 180)}</p>
                            </div>
                          </div>
                          <div class="shrink-0 rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs uppercase tracking-[0.16em] text-zinc-300">
                            {item.tags.slice(0, 2).join(" / ") || "-"}
                          </div>
                        </div>
                      </a>
                    ))}
                    <div class="flex flex-col gap-3 border-t border-white/8 pt-4 sm:flex-row sm:items-center sm:justify-between">
                      <span class="surface-label">Page {page}</span>
                      <div class="flex flex-wrap gap-2">
                        {prevPageHref ? (
                          <a class="inline-flex min-h-10 items-center rounded-full border border-white/10 bg-white/[0.04] px-4 text-sm text-zinc-200 transition duration-200 hover:border-white/20 hover:bg-white/[0.07]" href={prevPageHref}>Previous</a>
                        ) : (
                          <span class="inline-flex min-h-10 items-center rounded-full border border-white/6 bg-white/[0.03] px-4 text-sm text-zinc-500">Previous</span>
                        )}
                        {nextPageHref ? (
                          <a class="inline-flex min-h-10 items-center rounded-full border border-white/10 bg-white/[0.04] px-4 text-sm text-zinc-200 transition duration-200 hover:border-white/20 hover:bg-white/[0.07]" href={nextPageHref}>Next</a>
                        ) : (
                          <span class="inline-flex min-h-10 items-center rounded-full border border-white/6 bg-white/[0.03] px-4 text-sm text-zinc-500">Next</span>
                        )}
                      </div>
                    </div>
                  </div>
                ) : (
                  <div class="surface-soft-card">
                    <strong class="text-base font-semibold text-white">No memories found.</strong>
                    <p class="mt-2 text-sm leading-7 text-zinc-400">この tenant / project 条件ではまだ memory がありません。recent lane と search suggestions は profile データから先に埋めています。</p>
                  </div>
                )}
              </section>
            </div>
          ) : view === "profile" ? (
            <div class="grid gap-4 xl:grid-cols-2">
              <section class="surface-soft-card">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="surface-label">Durable</p>
                    <h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-white">Stable lane</h2>
                  </div>
                  <span class="surface-chip">{profile?.meta.durable_count ?? 0}</span>
                </div>
                <div class="mt-4 space-y-3">
                  {durableRows.length > 0 ? durableRows.map((item) => (
                    <a class={rowCardClass(selectedId === item.id)} href={makeHref({ selected: item.id })}>
                      <h3 class="text-lg font-semibold tracking-[-0.03em] text-white">{item.summary}</h3>
                      <p class="mt-2 text-sm leading-7 text-zinc-400">{item.content_preview}</p>
                      <span class="mt-3 block text-xs uppercase tracking-[0.16em] text-zinc-500">{item.source} / {formatDate(item.created_at)}</span>
                    </a>
                  )) : <div class="surface-soft-card !bg-white/[0.02] text-sm text-zinc-400">No durable rows.</div>}
                </div>
              </section>

              <section class="surface-soft-card bg-white/[0.02]">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="surface-label">Recent</p>
                    <h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-white">Temporal lane</h2>
                  </div>
                  <span class="surface-chip">{profile?.meta.recent_count ?? 0}</span>
                </div>
                <div class="mt-4 space-y-3">
                  {recentRows.length > 0 ? recentRows.map((item) => (
                    <a class={rowCardClass(selectedId === item.id)} href={makeHref({ selected: item.id })}>
                      <h3 class="text-lg font-semibold tracking-[-0.03em] text-white">{item.summary}</h3>
                      <p class="mt-2 text-sm leading-7 text-zinc-400">{item.content_preview}</p>
                      <span class="mt-3 block text-xs uppercase tracking-[0.16em] text-zinc-500">{item.source} / {formatDate(item.created_at)}</span>
                    </a>
                  )) : <div class="surface-soft-card !bg-white/[0.02] text-sm text-zinc-400">No recent rows.</div>}
                </div>
              </section>
            </div>
          ) : (
            <div class="space-y-5">
              <div class="flex flex-wrap items-end justify-between gap-4">
                <div>
                  <p class="surface-label">Maintenance</p>
                  <h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-white">Compaction summary</h2>
                </div>
                <p class="max-w-xl text-sm leading-7 text-zinc-400">structural change を先に出します。tag 分布と project footprint も同じ view 内で読めます。</p>
              </div>

              <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                <div class="surface-soft-card">
                  <span class="surface-label">Visible</span>
                  <strong class="mt-3 block text-4xl font-semibold tracking-[-0.04em] text-white">{listPage?.meta.total ?? 0}</strong>
                </div>
                <div class="surface-soft-card">
                  <span class="surface-label">Canonical</span>
                  <strong class="mt-3 block text-4xl font-semibold tracking-[-0.04em] text-white">{listPage?.meta.canonical_count ?? 0}</strong>
                </div>
                <div class="surface-soft-card">
                  <span class="surface-label">Digest</span>
                  <strong class="mt-3 block text-4xl font-semibold tracking-[-0.04em] text-white">{listPage?.meta.digest_count ?? 0}</strong>
                </div>
                <div class="surface-soft-card">
                  <span class="surface-label">Compacted</span>
                  <strong class="mt-3 block text-4xl font-semibold tracking-[-0.04em] text-white">{listPage?.meta.compacted_count ?? 0}</strong>
                </div>
              </div>

              <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_20rem]">
                <div class="surface-soft-card">
                  <p class="surface-label">Tag mix</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    <span class="surface-chip">canonical {maintenanceTagCounts["canonical-memory"] ?? 0}</span>
                    <span class="surface-chip">digest {maintenanceTagCounts["memory-digest"] ?? 0}</span>
                    <span class="surface-chip">compacted {maintenanceTagCounts["compacted"] ?? 0}</span>
                  </div>
                </div>
                <div class="surface-soft-card">
                  <p class="surface-label">Project footprint</p>
                  <div class="mt-4 space-y-3">
                    {maintenanceProjectRows.length > 0 ? maintenanceProjectRows.map(([project, count]) => (
                      <div class="flex items-center justify-between rounded-2xl border border-white/8 bg-white/[0.04] px-4 py-3">
                        <strong class="text-sm font-semibold text-white">{project}</strong>
                        <span class="text-xs uppercase tracking-[0.16em] text-zinc-400">{count} rows</span>
                      </div>
                    )) : <div class="text-sm text-zinc-400">No project footprint on this page.</div>}
                  </div>
                </div>
              </div>

              {maintenanceRows.length > 0 ? (
                <div class="space-y-3">
                  {maintenanceRows.map((item) => (
                    <a class={rowCardClass(selectedId === item.id)} href={makeHref({ selected: item.id })}>
                      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div class="flex min-w-0 gap-4">
                          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.05] font-mono text-sm font-semibold text-amber-100">
                            {item.tags.includes("canonical-memory") ? "C" : item.tags.includes("memory-digest") ? "D" : "X"}
                          </div>
                          <div class="min-w-0 space-y-2">
                            <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.16em] text-zinc-500">
                              <span>{item.project_id || "no-project"}</span>
                              <span>{item.source}</span>
                              <span>{formatDate(item.created_at)}</span>
                            </div>
                            <h3 class="text-xl font-semibold tracking-[-0.03em] text-white">{item.summary || trimText(item.content, 80) || "Untitled memory"}</h3>
                            <p class="text-sm leading-7 text-zinc-400">{trimText(item.content, 180)}</p>
                          </div>
                        </div>
                        <div class="shrink-0 rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs uppercase tracking-[0.16em] text-zinc-300">
                          {item.tags.filter((tag) => ["canonical-memory", "memory-digest", "compacted"].includes(tag)).join(" / ")}
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              ) : (
                <div class="surface-soft-card">
                  <strong class="text-base font-semibold text-white">No maintenance-tagged rows on this page.</strong>
                </div>
              )}
            </div>
          )}
        </div>
      </section>

      <aside class="xl:sticky xl:top-24">
        <div class="rounded-[30px] border border-white/10 bg-[linear-gradient(180deg,rgba(16,16,19,0.94)_0%,rgba(10,10,12,0.92)_100%)] p-5 shadow-[0_24px_80px_rgba(0,0,0,0.32)] backdrop-blur-xl">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="surface-label">Selected memory</p>
              <h2 class="mt-2 text-3xl font-semibold tracking-[-0.05em] text-white">{detail ? detail.title : "Pick a row"}</h2>
            </div>
            {detail?.score !== null && detail?.score !== undefined && (
              <span class="surface-chip">{detail.score.toFixed(3)}</span>
            )}
          </div>

          {detail ? (
            <div class="mt-5 space-y-4">
              <dl class="grid gap-3 sm:grid-cols-2">
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">ID</dt>
                  <dd class="mt-2 break-all text-sm leading-7 text-zinc-200">{detail.id}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Source</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{detail.source}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Project</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{detail.project_id || "no-project"}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Created</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{formatDate(detail.created_at)}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Kind</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{detail.kind} / {detail.memory_kind}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Lifecycle</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{detail.lifecycle_state}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Version</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">v{detail.current_version}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">External key</dt>
                  <dd class="mt-2 break-all text-sm leading-7 text-zinc-200">{detail.external_key || "n/a"}</dd>
                </div>
              </dl>

              {detail.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {detail.tags.map((tag) => <span class="surface-chip">{tag}</span>)}
                </div>
              )}

              <div class="grid gap-3 sm:grid-cols-3">
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Last accessed</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{detail.last_accessed_at ? formatDate(detail.last_accessed_at) : "n/a"}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Confidence</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{detail.confidence_score ?? "n/a"}</dd>
                </div>
                <div class="surface-soft-card !rounded-[22px] !p-4">
                  <dt class="surface-label">Utility</dt>
                  <dd class="mt-2 text-sm leading-7 text-zinc-200">{detail.utility_score ?? "n/a"}</dd>
                </div>
              </div>

              <section class="surface-soft-card !rounded-[24px] !p-4">
                <h3 class="text-base font-semibold text-white">Preview</h3>
                <p class="mt-3 text-sm leading-7 text-zinc-300">{detail.preview}</p>
              </section>

              {detail.content && detail.content !== detail.preview && (
                <details class="surface-soft-card !rounded-[24px] !p-4">
                  <summary class="cursor-pointer text-sm font-semibold text-white">Raw content</summary>
                  <pre class="mt-3">{detail.content}</pre>
                </details>
              )}
            </div>
          ) : (
            <div class="mt-5 space-y-4">
              <div class="surface-soft-card !rounded-[24px] !p-4">
                <strong class="text-base font-semibold text-white">検索前のクイックピック</strong>
                <p class="mt-2 text-sm leading-7 text-zinc-400">recent lane からすぐ開けるようにしています。検索語が定まっていないときはここから入れます。</p>
              </div>
              <div class="space-y-3">
                {quickPickRows.length > 0 ? quickPickRows.map((item) => (
                  <a class={rowCardClass(false)} href={makeHref({ selected: item.id })}>
                    <p class="surface-label">{item.source}</p>
                    <h3 class="mt-2 text-lg font-semibold tracking-[-0.03em] text-white">{item.summary}</h3>
                    <p class="mt-2 text-sm leading-7 text-zinc-400">{trimText(item.content_preview, 140)}</p>
                  </a>
                )) : (
                  <div class="surface-soft-card !rounded-[24px] !p-4 text-sm text-zinc-400">まだ quick pick に出せる memory がありません。</div>
                )}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
