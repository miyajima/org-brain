---
import BaseLayout from "../layouts/BaseLayout.astro";

type MemoryRow = {
  id: string;
  project_id: string | null;
  content: string;
  summary: string | null;
  tags: string[];
  source: string;
  external_key: string | null;
  created_at: number;
};

type MemorySearchResult = {
  kind: "memory" | "doc";
  id: string;
  summary: string | null;
  content_preview: string;
  score: number | null;
  source: string;
  created_at: number;
};

type MemoryProfileItem = {
  id: string;
  project_id: string | null;
  summary: string;
  content_preview: string;
  source: string;
  created_at: number;
  tags: string[];
};

type SearchResponse = {
  tenant_id: string;
  project_id: string | null;
  q: string;
  rewrite_query: boolean;
  search_mode: "memories" | "hybrid";
  include_history: boolean;
  results: MemorySearchResult[];
  meta: {
    search_strategy: string;
    matched_count: number;
    returned_count: number;
    fallback_used: boolean;
    variant_count: number;
  };
};

type ProfileResponse = {
  tenant_id: string;
  project_id: string | null;
  durable: MemoryProfileItem[];
  recent: MemoryProfileItem[];
  search_results: MemorySearchResult[];
  meta: {
    durable_count: number;
    recent_count: number;
  };
};

type MemoryListPage = {
  tenant_id: string;
  project_id: string | null;
  source: string | null;
  items: MemoryRow[];
  meta: {
    limit: number;
    offset: number;
    total: number;
    has_next: boolean;
    has_prev: boolean;
    canonical_count: number;
    digest_count: number;
    compacted_count: number;
  };
};

type ApiOk<T> = { ok: true; data: T };
type ApiErr = { ok: false; error?: { code?: string; message?: string } };
type ApiResponse<T> = ApiOk<T> | ApiErr;

type DetailRecord = {
  id: string;
  kind: "memory" | "doc";
  title: string;
  summary: string;
  preview: string;
  source: string;
  project_id: string | null;
  external_key: string | null;
  created_at: number;
  tags: string[];
  score: number | null;
  content: string;
};

const url = Astro.url;
const params = url.searchParams;

const tenantId = params.get("tenant_id")?.trim() || "default";
const projectId = params.get("project_id")?.trim() || "";
const query = params.get("q")?.trim() || "";
const selectedId = params.get("selected")?.trim() || "";
const view = ["search", "profile", "maintenance"].includes(params.get("view") ?? "")
  ? (params.get("view") as "search" | "profile" | "maintenance")
  : "search";
const rewriteQuery = params.get("rewrite_query") !== "0";
const searchMode = params.get("search_mode") === "memories" ? "memories" : "hybrid";
const includeHistory = params.get("include_history") !== "0";
const pageSize = Math.min(50, Math.max(10, Number.parseInt(params.get("page_size") ?? "20", 10) || 20));
const page = Math.max(1, Number.parseInt(params.get("page") ?? "1", 10) || 1);
const offset = (page - 1) * pageSize;

function formatDate(timestamp: number): string {
  return new Intl.DateTimeFormat("ja-JP", {
    timeZone: "Asia/Tokyo",
    dateStyle: "medium",
    timeStyle: "short"
  }).format(new Date(timestamp));
}

function trimText(value: string | null | undefined, limit = 180): string {
  const normalized = String(value ?? "").replace(/\s+/g, " ").trim();
  if (!normalized) return "";
  if (normalized.length <= limit) return normalized;
  return `${normalized.slice(0, Math.max(0, limit - 1))}...`;
}

function makeHref(overrides: Record<string, string | null | undefined>): string {
  const next = new URLSearchParams(params);
  for (const [key, value] of Object.entries(overrides)) {
    if (value === null || value === undefined || value === "") {
      next.delete(key);
    } else {
      next.set(key, value);
    }
  }
  const queryString = next.toString();
  return queryString ? `${url.pathname}?${queryString}` : url.pathname;
}

async function fetchApi<T>(path: string, init?: RequestInit): Promise<ApiResponse<T> | null> {
  const response = await fetch(new URL(path, url), init);
  const payload = (await response.json().catch(() => null)) as ApiResponse<T> | null;
  if (!response.ok) {
    return {
      ok: false,
      error: payload && "error" in payload ? payload.error : { code: "http_error", message: `HTTP ${response.status}` }
    };
  }
  if (!payload || payload.ok === false) {
    return payload ?? { ok: false, error: { code: "parse_error", message: "Invalid JSON response" } };
  }
  return payload;
}

function buildDetailRecord(
  selected: string,
  corpusItems: MemoryRow[],
  searchResults: MemorySearchResult[],
  profileItems: MemoryProfileItem[]
): DetailRecord | null {
  const row = corpusItems.find((item) => item.id === selected);
  if (row) {
    return {
      id: row.id,
      kind: "memory",
      title: row.summary || trimText(row.content, 80),
      summary: row.summary || "",
      preview: trimText(row.content, 320),
      source: row.source,
      project_id: row.project_id,
      external_key: row.external_key,
      created_at: row.created_at,
      tags: row.tags,
      score: searchResults.find((item) => item.id === selected)?.score ?? null,
      content: row.content
    };
  }

  const searchItem = searchResults.find((item) => item.id === selected);
  if (searchItem) {
    const profileItem = profileItems.find((item) => item.id === selected);
    return {
      id: searchItem.id,
      kind: searchItem.kind,
      title: searchItem.summary || trimText(searchItem.content_preview, 80),
      summary: searchItem.summary || "",
      preview: trimText(searchItem.content_preview, 320),
      source: searchItem.source,
      project_id: profileItem?.project_id ?? null,
      external_key: null,
      created_at: searchItem.created_at,
      tags: profileItem?.tags ?? [],
      score: searchItem.score,
      content: searchItem.content_preview
    };
  }

  const profileItem = profileItems.find((item) => item.id === selected);
  if (profileItem) {
    return {
      id: profileItem.id,
      kind: "memory",
      title: profileItem.summary,
      summary: profileItem.summary,
      preview: trimText(profileItem.content_preview, 320),
      source: profileItem.source,
      project_id: profileItem.project_id,
      external_key: null,
      created_at: profileItem.created_at,
      tags: profileItem.tags,
      score: null,
      content: profileItem.content_preview
    };
  }

  return null;
}

const listPayload = await fetchApi<MemoryListPage>(
  `/api/v1/memories?tenant_id=${encodeURIComponent(tenantId)}&project_id=${encodeURIComponent(projectId)}&limit=${pageSize}&offset=${offset}&paginated=1`
);

const searchPayload =
  query.length > 0
    ? await fetchApi<SearchResponse>("/api/v1/memories/search", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          tenant_id: tenantId,
          project_id: projectId || null,
          q: query,
          limit: 12,
          rewrite_query: rewriteQuery,
          search_mode: searchMode,
          include_history: includeHistory
        })
      })
    : null;

const profilePayload = await fetchApi<ProfileResponse>("/api/v1/memories/profile", {
  method: "POST",
  headers: { "content-type": "application/json" },
  body: JSON.stringify({
    tenant_id: tenantId,
    project_id: projectId || null,
    limit_durable: 8,
    limit_recent: 8,
    rewrite_query: rewriteQuery,
    search_mode: searchMode
  })
});

const listPage = listPayload?.ok ? listPayload.data : null;
const corpusItems = listPage?.items ?? [];
const searchResults = searchPayload?.ok ? searchPayload.data.results : [];
const profile = profilePayload?.ok ? profilePayload.data : null;
const durableRows = profile?.durable ?? [];
const recentRows = profile?.recent ?? [];
const detail = buildDetailRecord(selectedId, corpusItems, searchResults, [...durableRows, ...recentRows]);
const maintenanceRows = corpusItems.filter((item) =>
  item.tags.some((tag) => ["canonical-memory", "memory-digest", "compacted"].includes(tag))
);
const maintenanceTagCounts = maintenanceRows.reduce<Record<string, number>>((acc, item) => {
  for (const tag of item.tags) {
    if (!["canonical-memory", "memory-digest", "compacted"].includes(tag)) continue;
    acc[tag] = (acc[tag] ?? 0) + 1;
  }
  return acc;
}, {});
const maintenanceProjectCounts = maintenanceRows.reduce<Record<string, number>>((acc, item) => {
  const project = item.project_id || "no-project";
  acc[project] = (acc[project] ?? 0) + 1;
  return acc;
}, {});
const maintenanceProjectRows = Object.entries(maintenanceProjectCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4);

const loadErrors = [...new Set([
  listPayload?.ok === false ? listPayload.error?.message ?? "Memory list could not be loaded" : null,
  searchPayload?.ok === false ? searchPayload.error?.message ?? "Memory search could not be loaded" : null,
  profilePayload?.ok === false ? profilePayload.error?.message ?? "Memory profile could not be loaded" : null
].filter(Boolean) as string[])];

const prevPageHref = listPage?.meta.has_prev ? makeHref({ page: String(page - 1), selected: "" }) : null;
const nextPageHref = listPage?.meta.has_next ? makeHref({ page: String(page + 1), selected: "" }) : null;
const searchTabHref = makeHref({ view: "search", page: String(page) });
const profileTabHref = makeHref({ view: "profile", selected: "" });
const maintenanceTabHref = makeHref({ view: "maintenance", page: String(page), selected: "" });
const clearQueryHref = makeHref({ q: "", selected: "", page: "1" });
---
<BaseLayout title="Memory Explorer">
  <section class="memory-shell">
    <header class="memory-header card">
      <div class="header-copy">
        <p class="eyebrow">Memory workspace</p>
        <h1>Memory Explorer</h1>
        <p class="lede">検索、durable lanes、maintenance を 1 画面で読む operator workspace です。Apple らしい黒と白のコントラストで、情報の順番を先に見せます。</p>
      </div>
      <div class="header-stats">
        <span><em>{listPage?.meta.total ?? 0}</em> visible</span>
        <span><em>{listPage?.meta.canonical_count ?? 0}</em> canonical</span>
        <span><em>{listPage?.meta.digest_count ?? 0}</em> digest</span>
        <span><em>{listPage?.meta.compacted_count ?? 0}</em> compacted</span>
        <span><em>{profile?.meta.durable_count ?? 0}</em> durable</span>
        <span><em>{profile?.meta.recent_count ?? 0}</em> recent</span>
      </div>
    </header>

    <section class="controls card">
      <div class="tabbar" role="tablist" aria-label="Memory views">
        <a class={`tab ${view === "search" ? "is-active" : ""}`} href={searchTabHref}>Search</a>
        <a class={`tab ${view === "profile" ? "is-active" : ""}`} href={profileTabHref}>Profile</a>
        <a class={`tab ${view === "maintenance" ? "is-active" : ""}`} href={maintenanceTabHref}>Maintenance</a>
      </div>

      <form class="search-form" method="get" action="/memories">
        <input type="hidden" name="view" value={view} />
        <input type="hidden" name="page" value="1" />
        <label class="query-block">
          <span class="field-label">Search memories</span>
          <input
            type="search"
            name="q"
            value={query}
            placeholder="例: policy, maintenance, deploy, diagnosis"
          />
        </label>
        <button type="submit">Search</button>
      </form>

      <div class="filter-row">
        <form class="filter-form" method="get" action="/memories">
          <input type="hidden" name="view" value={view} />
          <input type="hidden" name="q" value={query} />
          <input type="hidden" name="page" value="1" />
          <label>
            <span class="field-label">Tenant</span>
            <input name="tenant_id" value={tenantId} />
          </label>
          <label>
            <span class="field-label">Project</span>
            <input name="project_id" value={projectId} placeholder="optional project filter" />
          </label>
          <label>
            <span class="field-label">Search mode</span>
            <select name="search_mode">
              <option value="hybrid" selected={searchMode === "hybrid"}>hybrid</option>
              <option value="memories" selected={searchMode === "memories"}>memories</option>
            </select>
          </label>
          <label>
            <span class="field-label">Rewrite</span>
            <select name="rewrite_query">
              <option value="1" selected={rewriteQuery}>on</option>
              <option value="0" selected={!rewriteQuery}>off</option>
            </select>
          </label>
          <label>
            <span class="field-label">Page size</span>
            <select name="page_size">
              <option value="10" selected={pageSize === 10}>10</option>
              <option value="20" selected={pageSize === 20}>20</option>
              <option value="50" selected={pageSize === 50}>50</option>
            </select>
          </label>
          <button type="submit">Apply</button>
        </form>
        {query && (
          <a class="secondary-link" href={clearQueryHref}>Clear search</a>
        )}
      </div>
    </section>

    {loadErrors.length > 0 && (
      <section class="warning card">
        <strong>Data fetch warning</strong>
        <ul>
          {loadErrors.map((message) => <li>{message}</li>)}
        </ul>
      </section>
    )}

    <div class="workspace">
      <section class="main-pane card">
        {view === "search" ? (
          <>
            <div class="section-head">
              <div>
                <p class="eyebrow">{query ? "Search results" : "Corpus list"}</p>
                <h2>{query ? "Ranked matches" : "Browse all memories"}</h2>
                <p class="muted">
                  {query
                    ? `検索時は上位一致だけを表示します。query が空のときは corpus 全体をページ送りで閲覧します。`
                    : `現在は ${listPage?.meta.total ?? 0} 件の corpus をページング表示しています。`}
                </p>
              </div>
              {query && searchPayload?.ok && (
                <div class="micro-meta">
                  <span>{searchPayload.data.meta.search_strategy}</span>
                  <span>{searchPayload.data.meta.returned_count} results</span>
                  <span>{searchPayload.data.meta.variant_count} variants</span>
                </div>
              )}
            </div>

            {query ? (
              searchResults.length > 0 ? (
                <div class="list">
                  {searchResults.map((item, index) => (
                    <a class={`list-row ${selectedId === item.id ? "is-selected" : ""}`} href={makeHref({ selected: item.id })}>
                      <div class="row-rank">{index + 1}</div>
                      <div class="row-main">
                        <div class="row-meta">
                          <span>{item.kind}</span>
                          <span>{item.source}</span>
                          <span>{formatDate(item.created_at)}</span>
                        </div>
                        <strong>{item.summary || "Untitled result"}</strong>
                        <p>{item.content_preview}</p>
                      </div>
                      <div class="row-side">{item.score === null ? "n/a" : item.score.toFixed(3)}</div>
                    </a>
                  ))}
                </div>
              ) : (
                <div class="empty-state">
                  <strong>No matches.</strong>
                  <p>語句を広げるか、`project` を空にして再検索してください。</p>
                  <div class="quick-picks">
                    <a href={clearQueryHref}>Clear query</a>
                    <a href={profileTabHref}>Profile</a>
                    <a href={maintenanceTabHref}>Maintenance</a>
                  </div>
                </div>
              )
            ) : corpusItems.length > 0 ? (
              <>
                <div class="list">
                  {corpusItems.map((item) => (
                    <a class={`list-row ${selectedId === item.id ? "is-selected" : ""}`} href={makeHref({ selected: item.id })}>
                      <div class="row-rank">{item.tags.includes("canonical-memory") ? "C" : item.tags.includes("memory-digest") ? "D" : item.tags.includes("compacted") ? "X" : "M"}</div>
                      <div class="row-main">
                        <div class="row-meta">
                          <span>{item.source}</span>
                          <span>{item.project_id || "no-project"}</span>
                          <span>{formatDate(item.created_at)}</span>
                        </div>
                        <strong>{item.summary || trimText(item.content, 80) || "Untitled memory"}</strong>
                        <p>{trimText(item.content, 180)}</p>
                      </div>
                      <div class="row-side">{item.tags.slice(0, 2).join(" / ") || "-"}</div>
                    </a>
                  ))}
                </div>
                <div class="pager">
                  <span>Page {page}</span>
                  <div class="pager-actions">
                    {prevPageHref ? <a class="pager-link" href={prevPageHref}>Previous</a> : <span class="pager-link is-disabled">Previous</span>}
                    {nextPageHref ? <a class="pager-link" href={nextPageHref}>Next</a> : <span class="pager-link is-disabled">Next</span>}
                  </div>
                </div>
              </>
            ) : (
              <div class="empty-state">
                <strong>No memories found.</strong>
                <p>この tenant / project 条件ではまだ memory がありません。</p>
                <div class="quick-picks">
                  <a href={profileTabHref}>Profile</a>
                  <a href={maintenanceTabHref}>Maintenance</a>
                </div>
              </div>
            )}
          </>
        ) : view === "profile" ? (
          <div class="two-pane">
            <section class="subpane">
              <div class="section-head compact">
                <div>
                  <p class="eyebrow">Durable</p>
                  <h2>Stable lane</h2>
                </div>
                <span class="counter">{profile?.meta.durable_count ?? 0}</span>
              </div>
              {durableRows.length > 0 ? (
                <div class="stack">
                  {durableRows.map((item) => (
                    <a class={`stack-row ${selectedId === item.id ? "is-selected" : ""}`} href={makeHref({ selected: item.id })}>
                      <strong>{item.summary}</strong>
                      <p>{item.content_preview}</p>
                      <span>{item.source} / {formatDate(item.created_at)}</span>
                    </a>
                  ))}
                </div>
              ) : <div class="empty-state"><strong>No durable rows.</strong></div>}
            </section>

            <section class="subpane">
              <div class="section-head compact">
                <div>
                  <p class="eyebrow">Recent</p>
                  <h2>Temporal lane</h2>
                </div>
                <span class="counter">{profile?.meta.recent_count ?? 0}</span>
              </div>
              {recentRows.length > 0 ? (
                <div class="stack">
                  {recentRows.map((item) => (
                    <a class={`stack-row ${selectedId === item.id ? "is-selected" : ""}`} href={makeHref({ selected: item.id })}>
                      <strong>{item.summary}</strong>
                      <p>{item.content_preview}</p>
                      <span>{item.source} / {formatDate(item.created_at)}</span>
                    </a>
                  ))}
                </div>
              ) : <div class="empty-state"><strong>No recent rows.</strong></div>}
            </section>
          </div>
        ) : (
          <>
            <div class="section-head">
              <div>
                <p class="eyebrow">Maintenance</p>
                <h2>Compaction summary</h2>
                <p class="muted">structural change を先に見せます。maintenance の主要指標、タグ分布、project footprint だけを出します。</p>
              </div>
            </div>
            <div class="maintenance-grid">
              <div class="maintenance-metric">
                <span>Visible</span>
                <strong>{listPage?.meta.total ?? 0}</strong>
              </div>
              <div class="maintenance-metric">
                <span>Canonical</span>
                <strong>{listPage?.meta.canonical_count ?? 0}</strong>
              </div>
              <div class="maintenance-metric">
                <span>Digest</span>
                <strong>{listPage?.meta.digest_count ?? 0}</strong>
              </div>
              <div class="maintenance-metric">
                <span>Compacted</span>
                <strong>{listPage?.meta.compacted_count ?? 0}</strong>
              </div>
            </div>
            {maintenanceProjectRows.length > 0 && (
              <div class="maintenance-footprint">
                <h3>Project footprint</h3>
                <div class="maintenance-projects">
                  {maintenanceProjectRows.map(([project, count]) => (
                    <div class="maintenance-project">
                      <strong>{project}</strong>
                      <span>{count} rows</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
            <div class="maintenance-tags">
              <span>Canonical {maintenanceTagCounts["canonical-memory"] ?? 0}</span>
              <span>Digest {maintenanceTagCounts["memory-digest"] ?? 0}</span>
              <span>Compacted {maintenanceTagCounts["compacted"] ?? 0}</span>
            </div>
            {maintenanceRows.length > 0 ? (
              <div class="list">
                {maintenanceRows.map((item) => (
                  <a class={`list-row ${selectedId === item.id ? "is-selected" : ""}`} href={makeHref({ selected: item.id })}>
                    <div class="row-rank">{item.tags.includes("canonical-memory") ? "C" : item.tags.includes("memory-digest") ? "D" : "X"}</div>
                    <div class="row-main">
                      <div class="row-meta">
                        <span>{item.project_id || "no-project"}</span>
                        <span>{item.source}</span>
                        <span>{formatDate(item.created_at)}</span>
                      </div>
                      <strong>{item.summary || trimText(item.content, 80) || "Untitled memory"}</strong>
                      <p>{trimText(item.content, 180)}</p>
                    </div>
                    <div class="row-side">{item.tags.filter((tag) => ["canonical-memory", "memory-digest", "compacted"].includes(tag)).join(" / ")}</div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="empty-state">
                <strong>No maintenance-tagged rows on this page.</strong>
              </div>
            )}
            <div class="pager">
              <span>Page {page}</span>
              <div class="pager-actions">
                {prevPageHref ? <a class="pager-link" href={prevPageHref}>Previous</a> : <span class="pager-link is-disabled">Previous</span>}
                {nextPageHref ? <a class="pager-link" href={nextPageHref}>Next</a> : <span class="pager-link is-disabled">Next</span>}
              </div>
            </div>
          </>
        )}
      </section>

      <aside class="detail card">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Selected memory</p>
            <h2>{detail ? detail.title : "Choose a row"}</h2>
          </div>
        </div>
        {detail ? (
          <>
            <dl class="detail-grid">
              <div><dt>ID</dt><dd>{detail.id}</dd></div>
              <div><dt>Source</dt><dd>{detail.source}</dd></div>
              <div><dt>Project</dt><dd>{detail.project_id || "no-project"}</dd></div>
              <div><dt>Created</dt><dd>{formatDate(detail.created_at)}</dd></div>
              <div><dt>Score</dt><dd>{detail.score === null ? "n/a" : detail.score.toFixed(3)}</dd></div>
              <div><dt>External key</dt><dd>{detail.external_key || "n/a"}</dd></div>
            </dl>
            {detail.tags.length > 0 && (
              <div class="tags">
                {detail.tags.map((tag) => <span>{tag}</span>)}
              </div>
            )}
            <section class="detail-body">
              <h3>Preview</h3>
              <p>{detail.preview}</p>
            </section>
            {detail.content && detail.content !== detail.preview && (
              <details class="detail-body">
                <summary>Raw content</summary>
                <pre>{detail.content}</pre>
              </details>
            )}
          </>
        ) : (
          <div class="empty-state">
            <strong>まず左の一覧を操作してください。</strong>
            <p>入力欄で検索するか、query を空にして corpus list をページ送りで見ます。</p>
            <div class="quick-picks">
              <a href={searchTabHref}>Search</a>
              <a href={profileTabHref}>Profile</a>
              <a href={maintenanceTabHref}>Maintenance</a>
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>

  <style>
    .memory-shell {
      display: grid;
      gap: 18px;
    }

    .memory-header,
    .controls,
    .main-pane,
    .detail,
    .warning {
      overflow: hidden;
      margin-bottom: 0;
    }

    .memory-header {
      display: grid;
      gap: 14px;
      align-items: end;
