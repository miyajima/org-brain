---
import BaseLayout from "../layouts/BaseLayout.astro";

type ApiOk<T> = { ok: true; data: T };
type ApiErr = { ok: false; error?: { code?: string; message?: string } };
type ApiResponse<T> = ApiOk<T> | ApiErr;

type Identity = {
  tenant_id: string;
  auth: {
    principal: string;
    source: string;
    allowed_tenants: string[];
    email: string | null;
    display_name: string | null;
  };
  profile: {
    display_name: string | null;
    email: string | null;
    company_name: string | null;
    organization_name: string | null;
    avatar_url: string | null;
  };
};

const url = Astro.url;
const params = url.searchParams;
const tenantId = params.get("tenant_id")?.trim() || "default";
let message = "";
let error = "";

async function fetchApi<T>(path: string, init?: RequestInit): Promise<ApiResponse<T> | null> {
  const response = await fetch(new URL(path, url), init);
  const payload = (await response.json().catch(() => null)) as ApiResponse<T> | null;
  if (!response.ok) return payload ?? { ok: false, error: { message: `HTTP ${response.status}` } };
  return payload;
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const payload = {
    tenant_id: tenantId,
    display_name: String(form.get("display_name") ?? ""),
    email: String(form.get("email") ?? ""),
    company_name: String(form.get("company_name") ?? ""),
    organization_name: String(form.get("organization_name") ?? ""),
    avatar_url: String(form.get("avatar_url") ?? "")
  };
  const saved = await fetchApi("/api/v1/auth/me/profile", {
    method: "PUT",
    headers: { "content-type": "application/json" },
    body: JSON.stringify(payload)
  });
  if (saved?.ok) message = "Saved";
  else error = saved?.error?.message ?? "Profile could not be saved";
}

const identityPayload = await fetchApi<Identity>(`/api/v1/auth/me?tenant_id=${encodeURIComponent(tenantId)}`);
const identity = identityPayload?.ok ? identityPayload.data : null;
if (identityPayload?.ok === false) error = identityPayload.error?.message ?? "Profile could not be loaded";
---
<BaseLayout title="Profile">
  <section class="space-y-5">
    <header class="rounded-[22px] border border-white/10 bg-white/[0.04] p-5">
      <p class="surface-label">Identity</p>
      <h1 class="mt-2 text-3xl font-semibold text-white">Profile</h1>
      {identity && <p class="mt-3 text-sm text-zinc-400">{identity.auth.principal} · {identity.auth.source}</p>}
    </header>

    {message && <div class="rounded-lg border border-emerald-300/20 bg-emerald-400/10 p-3 text-sm text-emerald-100">{message}</div>}
    {error && <div class="rounded-lg border border-rose-300/20 bg-rose-400/10 p-3 text-sm text-rose-100">{error}</div>}

    <form method="post" class="grid gap-4 rounded-[22px] border border-white/8 bg-zinc-950/50 p-5 md:grid-cols-2">
      <input type="hidden" name="tenant_id" value={tenantId} />
      <label>
        <span class="field-label">Display name</span>
        <input name="display_name" value={identity?.profile.display_name ?? identity?.auth.display_name ?? ""} />
      </label>
      <label>
        <span class="field-label">Email</span>
        <input name="email" value={identity?.profile.email ?? identity?.auth.email ?? ""} />
      </label>
      <label>
        <span class="field-label">Company name</span>
        <input name="company_name" value={identity?.profile.company_name ?? ""} />
      </label>
      <label>
        <span class="field-label">Organization name</span>
        <input name="organization_name" value={identity?.profile.organization_name ?? ""} />
      </label>
      <label class="md:col-span-2">
        <span class="field-label">Avatar URL</span>
        <input name="avatar_url" value={identity?.profile.avatar_url ?? ""} />
      </label>
      <div class="md:col-span-2">
        <button type="submit">Save</button>
      </div>
    </form>
  </section>
</BaseLayout>
