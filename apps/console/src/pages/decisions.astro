---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  confirmationLabel as decisionConfirmationLabel,
  freshnessLabel as decisionFreshnessLabel,
  isExpired,
  isHumanConfirmed,
  isUnconfirmedInference,
  LOCALES,
  normalizeLocale,
  operationLabel as decisionOperationLabel,
  refLabel,
  statusLabel as decisionStatusLabel,
  type Locale,
  type OwnerRef,
  type SourceRef
} from "../lib/decision-ui";

type DecisionMemory = {
  id: string;
  tenantId: string;
  projectId: string | null;
  domain: string;
  title: string;
  decision: string;
  rationale: string;
  constraints: string[];
  knownPitfalls: string[];
  sourceRefs: SourceRef[];
  ownerRefs: OwnerRef[];
  reviewerRefs: OwnerRef[];
  validFrom: number | null;
  validUntil: number | null;
  status: string;
  supersededBy: string | null;
  confidence: number;
  visibility: string;
  confirmationState: string;
  confirmationNote: string | null;
  confirmedAt: number | null;
  createdAt: number;
  updatedAt: number;
  score?: { finalScore?: number; sourceAuthority?: number };
  trustSignals?: {
    confidence: number;
    confirmationState: string;
    humanConfirmed: boolean;
    sourceAuthority: number;
    sourceCount: number;
    ownerCount: number;
    reviewerCount: number;
    freshness: string;
    conflictCount: number;
    visibility?: string;
    permissionFilteredSourceCount?: number;
  };
};

type DecisionVersion = {
  id: string;
  operation: string;
  actorRefs: OwnerRef[];
  reviewerRefs: OwnerRef[];
  note: string | null;
  createdAt: number;
};

type DecisionContext = {
  decisionMemory: DecisionMemory;
  whyTrustThis: {
    trustSignals: NonNullable<DecisionMemory["trustSignals"]>;
    provenance: {
      decidedBy: OwnerRef[];
      reviewedBy: OwnerRef[];
      sourceRefs: SourceRef[];
      createdAt: number;
      updatedAt: number;
      confirmedAt: number | null;
      confirmationNote: string | null;
      applicableContext: {
        domain: string;
        projectId: string | null;
        validFrom: number | null;
        validUntil: number | null;
        status: string;
        constraints: string[];
        knownPitfalls: string[];
      };
    };
    conflicts: Array<{
      topic: string;
      preferredMemoryId: string;
      conflictingMemoryIds: string[];
      severity: string;
      requiresHumanReview: boolean;
    }>;
    versions: DecisionVersion[];
  };
  related: Array<{
    id: string;
    title: string;
    decision: string;
    status: string;
    confirmationState: string;
  }>;
};

type SearchResponse = {
  tenant_id: string;
  project_id: string | null;
  q: string;
  results: DecisionMemory[];
};

type ApiOk<T> = { ok: true; data: T };
type ApiErr = { ok: false; error?: { code?: string; message?: string } };
type ApiResponse<T> = ApiOk<T> | ApiErr;

