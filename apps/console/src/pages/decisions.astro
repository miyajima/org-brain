const url = Astro.url;
const params = url.searchParams;
const tenantId = params.get("tenant_id")?.trim() || "default";
const projectId = params.get("project_id")?.trim() || "";
const query = params.get("q")?.trim() || "";
const personId = params.get("person_id")?.trim() || "";
const reviewerId = params.get("reviewer_id")?.trim() || "";
const confirmationState = params.get("confirmation_state")?.trim() || "";
const selectedId = params.get("selected")?.trim() || "";
const locale = normalizeLocale(params.get("lang"));
const copy = PAGE_COPY[locale];
const dateLocale = locale === "ja" ? "ja-JP" : locale === "zh" ? "zh-CN" : "en-US";
const createMode = params.get("mode") === "create";
const requestedView = params.get("view")?.trim() || "results";
const mobileView = ["results", "editor", "trust"].includes(requestedView) ? requestedView : "results";
const advancedOpen = Boolean(personId || reviewerId || confirmationState);
const now = Date.now();

const confirmationLabel = (value: string | null | undefined) => decisionConfirmationLabel(value, locale);
const statusLabel = (value: string | null | undefined) => decisionStatusLabel(value, locale);
const freshnessLabel = (value: string | null | undefined) => decisionFreshnessLabel(value, locale);
const operationLabel = (value: string | null | undefined) => decisionOperationLabel(value, locale);

async function fetchApi<T>(path: string, init?: RequestInit): Promise<ApiResponse<T> | null> {
  const response = await fetch(new URL(path, url), init);
  const payload = (await response.json().catch(() => null)) as ApiResponse<T> | null;
  if (!response.ok) {
    return {
      ok: false,
      error: payload && "error" in payload ? payload.error : { code: "http_error", message: `HTTP ${response.status}` }
    };
  }
  return payload ?? { ok: false, error: { code: "parse_error", message: "Invalid JSON response" } };
}

function makeHref(overrides: Record<string, string | null | undefined>): string {
  const next = new URLSearchParams(params);
  for (const [key, value] of Object.entries(overrides)) {
    if (value === null || value === undefined || value === "") next.delete(key);
    else next.set(key, value);
  }
  const queryString = next.toString();
  return queryString ? `${url.pathname}?${queryString}` : url.pathname;
}

function formatDate(timestamp: number | null | undefined): string {
  if (!timestamp) return "-";
  return new Intl.DateTimeFormat(dateLocale, {
    timeZone: "Asia/Tokyo",
    dateStyle: "medium",
    timeStyle: "short"
  }).format(new Date(timestamp));
}

function dateTimeValue(timestamp: number | null | undefined): string {
  if (!timestamp) return "";
  return new Date(timestamp).toISOString().slice(0, 16);
}

function trimText(value: string | null | undefined, limit = 160): string {
  const normalized = String(value ?? "").replace(/\s+/g, " ").trim();
  if (!normalized) return "";
  return normalized.length > limit ? `${normalized.slice(0, limit - 1)}...` : normalized;
}

function lines(value: string[] | null | undefined): string {
  return (value ?? []).join("\n");
}

function percent(value: number | null | undefined): string {
  if (typeof value !== "number" || !Number.isFinite(value)) return "-";
  return `${Math.round(value * 100)}%`;
}

function ownerRows(refs: OwnerRef[] | null | undefined): OwnerRef[] {
  return refs && refs.length > 0 ? refs : [{ type: "user", id: "", name: "" }];
}

function sourceRows(refs: SourceRef[] | null | undefined): SourceRef[] {
  return refs && refs.length > 0 ? refs : [{ type: "doc", id: "", title: "", url: "", updatedAt: "" }];
}

function compactRefs(refs: OwnerRef[] | SourceRef[] | null | undefined, limit = 2): string {
  const labels = (refs ?? []).map(refLabel).filter(Boolean);
  if (labels.length === 0) return "-";
  const shown = labels.slice(0, limit).join(", ");
  return labels.length > limit ? `${shown} + ${labels.length - limit} more` : shown;
}

function sourceCount(memory: DecisionMemory): number {
  return memory.trustSignals?.sourceCount ?? memory.sourceRefs.length;
}

function conflictCount(memory: DecisionMemory): number {
  return memory.trustSignals?.conflictCount ?? 0;
}

function freshness(memory: DecisionMemory): string {
  return freshnessLabel(memory.trustSignals?.freshness);
}

function trustWarnings(memory: DecisionMemory): string[] {
  const warnings = [];
  if (isUnconfirmedInference(memory.confirmationState)) warnings.push(copy.unconfirmedWarning);
  if (conflictCount(memory) > 0) warnings.push(copy.conflictWarning);
  if (isExpired(memory.validUntil, now)) warnings.push(copy.expiredWarning);
  return warnings;
}

function panelClass(view: string): string {
  return [mobileView === view ? "block" : "hidden", "xl:block"].join(" ");
}

const searchPayload = await fetchApi<SearchResponse>("/api/v1/decision-memories/search", {
  method: "POST",
  headers: { "content-type": "application/json" },
  body: JSON.stringify({
    tenant_id: tenantId,
    project_id: projectId || null,
    q: query,
    person_id: personId || undefined,
    reviewer_id: reviewerId || undefined,
    confirmation_state: confirmationState || undefined,
    include_provenance: true,
    authority_scoring: true,
    verification_view: true,
    limit: 24
  })
});

const results = searchPayload?.ok ? searchPayload.data.results : [];
const activeId = !createMode ? selectedId || results[0]?.id || "" : "";
const contextPayload = activeId
  ? await fetchApi<DecisionContext>(
      `/api/v1/decision-memories/${encodeURIComponent(activeId)}/context?tenant_id=${encodeURIComponent(tenantId)}`
    )
  : null;
const context = contextPayload?.ok ? contextPayload.data : null;
const active = context?.decisionMemory ?? results.find((item) => item.id === activeId) ?? null;
const errors = [
  searchPayload?.ok === false ? searchPayload.error?.message ?? "Decision search could not be loaded" : null,
  contextPayload?.ok === false ? contextPayload.error?.message ?? "Decision context could not be loaded" : null
].filter(Boolean) as string[];
const reviewedCount = results.filter((item) => isHumanConfirmed(item.confirmationState)).length;
const selectedSummary = active ?? results[0] ?? null;
---
<BaseLayout title={copy.pageTitle} lang={locale}>
  <section class="decision-page space-y-5">
    <header class="overflow-hidden rounded-[24px] border border-white/10 bg-[linear-gradient(180deg,rgba(7,7,8,0.96)_0%,rgba(10,10,12,0.92)_100%)] p-5 shadow-[0_30px_90px_rgba(0,0,0,0.36)] sm:p-7">
      <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_auto] xl:items-end">
        <div class="space-y-3">
          <p class="surface-label">{copy.eyebrow}</p>
          <h1 class="text-3xl font-semibold text-white sm:text-5xl">{copy.heading}</h1>
          <p class="max-w-3xl text-base leading-8 text-zinc-300">
            {copy.subtitle}
          </p>
        </div>
        <div class="flex flex-wrap gap-2 xl:justify-end" aria-label={copy.language}>
          {LOCALES.map((item) => (
            <a class={["trust-chip", locale === item.code ? "trust-chip-good" : ""].join(" ")} href={makeHref({ lang: item.code })} aria-current={locale === item.code ? "page" : undefined}>
              {item.label}
            </a>
          ))}
          <span class="trust-chip">{results.length} {copy.resultsUnit}</span>
          <span class="trust-chip trust-chip-good">{reviewedCount} {copy.reviewedUnit}</span>
          <span class="trust-chip">{tenantId}</span>
          {projectId && <span class="trust-chip">{projectId}</span>}
        </div>
      </div>
    </header>

    <section class="rounded-[22px] border border-white/8 bg-white/[0.04] p-4 shadow-[0_22px_70px_rgba(0,0,0,0.28)] sm:p-5">
      <form class="grid gap-4 lg:grid-cols-[minmax(0,1.5fr)_minmax(11rem,0.75fr)_minmax(11rem,0.75fr)_auto] lg:items-end" method="get" action="/decisions">
        <label>
          <span class="field-label">{copy.search}</span>
          <input name="q" value={query} placeholder="auth policy / deploy / review" />
        </label>
        <label>
          <span class="field-label">{copy.tenant}</span>
          <input name="tenant_id" value={tenantId} />
        </label>
        <label>
          <span class="field-label">{copy.project}</span>
          <input name="project_id" value={projectId} placeholder={copy.projectPlaceholder} />
        </label>
        <button type="submit">{copy.search}</button>
        <details class="advanced-filters lg:col-span-4" open={advancedOpen}>
          <summary>{copy.advancedFilters}</summary>
          <div class="mt-4 grid gap-4 md:grid-cols-3">
            <label>
              <span class="field-label">{copy.decider}</span>
              <input name="person_id" value={personId} placeholder="person id" />
            </label>
            <label>
              <span class="field-label">{copy.reviewer}</span>
              <input name="reviewer_id" value={reviewerId} placeholder="reviewer id" />
            </label>
            <label>
              <span class="field-label">{copy.confirmationState}</span>
              <select name="confirmation_state">
                <option value="" selected={!confirmationState}>{copy.all}</option>
                <option value="draft" selected={confirmationState === "draft"}>{confirmationLabel("draft")}</option>
                <option value="inferred_unconfirmed" selected={confirmationState === "inferred_unconfirmed"}>{confirmationLabel("inferred_unconfirmed")}</option>
                <option value="user_confirmed" selected={confirmationState === "user_confirmed"}>{confirmationLabel("user_confirmed")}</option>
                <option value="user_corrected" selected={confirmationState === "user_corrected"}>{confirmationLabel("user_corrected")}</option>
                <option value="reviewed" selected={confirmationState === "reviewed"}>{confirmationLabel("reviewed")}</option>
              </select>
            </label>
          </div>
        </details>
      </form>
    </section>

    {errors.length > 0 && (
      <section class="rounded-[22px] border border-rose-300/25 bg-rose-400/8 p-5">
        <strong class="block text-sm font-semibold text-rose-100">{copy.dataSourceError}</strong>
        <details class="mt-3 text-sm leading-7 text-rose-100/80">
          <summary>{copy.details}</summary>
          <ul class="mt-2 list-disc space-y-2 pl-5">
            {errors.map((message) => <li>{message}</li>)}
          </ul>
        </details>
      </section>
    )}

    {selectedSummary && (
      <section class="xl:hidden rounded-[20px] border border-white/8 bg-white/[0.04] p-4">
        <p class="surface-label">{copy.selected}</p>
        <h2 class="mt-2 text-xl font-semibold text-white">{selectedSummary.title}</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          <span class="trust-chip">{confirmationLabel(selectedSummary.confirmationState)}</span>
          <span class="trust-chip">{statusLabel(selectedSummary.status)}</span>
          <span class="trust-chip">{percent(selectedSummary.confidence)}</span>
          {trustWarnings(selectedSummary).map((warning) => <span class="trust-chip trust-chip-warn">{warning}</span>)}
        </div>
      </section>
    )}

    <nav class="decision-tabs xl:hidden" aria-label={copy.language}>
      <a href={makeHref({ view: "results" })} aria-current={mobileView === "results" ? "page" : undefined}>{copy.tabDecisions}</a>
