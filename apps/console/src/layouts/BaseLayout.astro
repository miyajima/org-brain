---
import "../styles/global.css";

const { title = "Org Brain Console" } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  if (href === "/tasks") return currentPath === "/tasks" || (currentPath.startsWith("/tasks/") && currentPath !== "/tasks/new");
  if (href === "/tasks/new") return currentPath === "/tasks/new";
  return currentPath === href;
};
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#09090b" />
    <link rel="icon" href="data:," />
    <title>{title}</title>
  </head>
  <body>
    <div class="console-shell">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(250,204,21,0.08),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.08),transparent_22%)]"></div>
      <nav class="console-nav">
        <span class="console-brand">Org Brain</span>
        <a class="console-nav-link" href="/" aria-current={isActive("/") ? "page" : undefined}>Dashboard</a>
        <a class="console-nav-link" href="/memories" aria-current={isActive("/memories") ? "page" : undefined}>Memories</a>
        <a class="console-nav-link" href="/tasks/new" aria-current={isActive("/tasks/new") ? "page" : undefined}>Task作成</a>
        <a class="console-nav-link" href="/tasks" aria-current={isActive("/tasks") ? "page" : undefined}>Task一覧</a>
      </nav>
      <main class="console-main">
        <slot />
      </main>
    </div>
  </body>
</html>
