# Org Brain local defaults
ORGBRAIN_LOCAL_DB=~/.org-brain/memory.sqlite

# Optional API bridge values for self-hosted Cloudflare or the managed SaaS.
# Do not commit real secrets.
# Cloudflare-backed memory is opt-in. Keep both OFF for local-only personal use.
ORGBRAIN_ENABLE_CLOUD_MEMORY=false
ORGBRAIN_ENABLE_ORG_SHARING=false
ORGBRAIN_API_URL=http://127.0.0.1:8787
ORGBRAIN_API_KEY=dev-org-brain-api-key
ORGBRAIN_TENANT_ID=default

# Gateway-side identity examples:
# API key requests use the grant principal as canonical identity.
# Cloudflare Access login requests use user:<Access sub> as canonical identity.
# Configure these in apps/api-gateway/.dev.vars or the deployed Worker env.

# Optional benchmark judge key.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
