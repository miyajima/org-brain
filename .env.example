# Org Brain local defaults
ORGBRAIN_LOCAL_DB=~/.org-brain/memory.sqlite

# Optional API bridge values for self-hosted Cloudflare or the managed SaaS.
# Do not commit real secrets.
ORGBRAIN_API_URL=http://127.0.0.1:8787
ORGBRAIN_API_KEY=dev-org-brain-api-key
ORGBRAIN_TENANT_ID=default

